              ],
              "sql_template": "{{#if databaseName}}USE `{{databaseName}}`;\n{{/if}}{{#if isPrimaryKey}}ALTER TABLE `{{tableName}}` DROP PRIMARY KEY;{{else}}ALTER TABLE `{{tableName}}` DROP INDEX{{#if ifExists}} IF EXISTS{{/if}} `{{indexName}}`;{{/if}}"
            }
          ]
