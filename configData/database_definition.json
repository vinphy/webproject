                { "key": "ifExists", "type": "checkbox", "label": "IF EXISTS" }
              ],
              "sql_template": "{{#if databaseName}}USE `{{databaseName}}`;\n{{/if}}{{#each tableName}}DROP TABLE{{#if ../ifExists}} IF EXISTS{{/if}} `{{this}}`;\n{{/each}}"
