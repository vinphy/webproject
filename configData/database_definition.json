              ],
              "sql_template": "{{#if databaseName}}USE `{{databaseName}}`;\n{{/if}}{{#each viewName}}DROP VIEW{{#if ../ifExists}} IF EXISTS{{/if}} `{{this}}`;\n{{/each}}"
