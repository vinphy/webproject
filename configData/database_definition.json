              "sql_template": "{{#if databaseName}}USE `{{databaseName}}`;\n{{/if}}{{#if isAdd}}ALTER TABLE `{{tableName}}` ADD `{{fieldName}}` {{dataType}}{{#if notNull}} NOT NULL{{/if}}{{#if primaryKey}} PRIMARY KEY{{/if}}{{#if autoIncrement}} AUTO_INCREMENT{{/if}}{{#if comment}} COMMENT '{{comment}}'{{/if}};{{/if}}{{#if isModify}}ALTER TABLE `{{tableName}}` MODIFY `{{fieldName}}` {{dataType}}{{#if notNull}} NOT NULL{{/if}}{{#if primaryKey}} PRIMARY KEY{{/if}}{{#if autoIncrement}} AUTO_INCREMENT{{/if}}{{#if comment}} COMMENT '{{comment}}'{{/if}};{{/if}}{{#if isDrop}}ALTER TABLE `{{tableName}}` DROP COLUMN `{{fieldName}}`;{{/if}}"
            },
            {
              "id": "viewU",
