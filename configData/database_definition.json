              "sql_template": "{{#if databaseName}}USE `{{databaseName}}`;\n{{/if}}CREATE OR REPLACE VIEW `{{viewName}}` AS SELECT {{#each columns}}`{{this}}`{{#unless @last}},{{/unless}}{{/each}} FROM `{{tableName}}`{{#if conditions.length}} WHERE {{#each conditions}}`{{field}}` {{operator}} '{{value}}'{{#unless @last}} AND {{/unless}}{{/each}}{{/if}}{{#if withCheckOption}} WITH CHECK OPTION{{/if}};"
            },
            {
              "id": "indexU",
